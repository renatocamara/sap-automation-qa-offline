# answers.env — non-interactive inputs for setup-and-run.sh
#
# Copy to answers.env, fill in, then run:  ./setup-and-run.sh --answers answers.env
# Using an answers file runs unattended (no prompts) and lets your security team
# review every input before anything executes.

# --- required ---------------------------------------------------------------
SID="X00"                                   # SAP SID (3 chars)
SYSTEM_CONFIG_NAME="PRD-EUS2-SAP01-X00"     # workspace folder name (ENV-REGION-VNET-SID)
SSH_USER="azureadm"                         # SSH user on the SAP servers

# SAP servers: space-separated "tier:hostname:ip" items.
# tiers: db, scs, ers, app, pas, web
HOSTS="db:vm-sapdb01:10.20.1.36 scs:vm-sapascs01:10.20.1.37"

# --- credentials ------------------------------------------------------------
AUTH_MODE="agent"                           # agent | keyfile
# If AUTH_MODE=keyfile, point at the private key (copied into the workspace, chmod 600):
# AUTH_MODE="keyfile"
# SSH_KEY_PATH="/home/azureadm/sap-checks-key"

# --- Azure -------------------------------------------------------------------
AZURE_ACCESS="no"                           # no => fully offline (skips Azure auth)

# --- SAP parameters (defaults shown; change only if needed) -----------------
DB_SID="HDB"
PLATFORM="HANA"                             # HANA / Db2 / ORACLE / SQLSERVER
SCS_HA="false"
DB_HA="false"
SCS_INSTANCE="00"
ERS_INSTANCE="01"
DB_INSTANCE="00"
NFS_PROVIDER="AFS"                          # AFS | ANF

# --- paths / behavior (optional) --------------------------------------------
# BUNDLE="$HOME/sapqa-offline-bundle.tar.gz"
# REINSTALL="0"                             # 1 = force re-extract + re-install
